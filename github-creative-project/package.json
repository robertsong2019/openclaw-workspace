{
  "name": "12-factor-agents-explorer",
  "version": "1.0.0",
  "description": "A creative framework for AI Agent development with embedded AI capabilities and rapid prototyping features",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "examples": "ts-node examples/comprehensive-demo.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "clean": "rm -rf dist",
    "docs": "typedoc src --out docs"
  },
  "keywords": [
    "ai-agent",
    "multimodal",
    "adaptive-learning",
    "collaborative-ai",
    "rapid-prototyping",
    "embedded-ai",
    "machine-learning",
    "typescript"
  ],
  "author": "robertsong2019",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robertsong2019/12-factor-agents-explorer.git"
  },
  "bugs": {
    "url": "https://github.com/robertsong2019/12-factor-agents-explorer/issues"
  },
  "homepage": "https://github.com/robertsong2019/12-factor-agents-explorer#readme",
  "dependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "eventemitter3": "^5.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typedoc": "^0.25.0",
    "prettier": "^3.0.0",
    "@types/prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*",
    "src/**/*.ts",
    "examples/**/*.ts",
    "docs/**/*",
    "README.md",
    "LICENSE"
  ]
}